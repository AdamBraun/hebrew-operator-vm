  Th99 -> V95 [xlabel="vav"];
  Trans -> Omega [xlabel="vav"];
  Trans -> Omega [xlabel="vav"];
  Trans -> Omega [xlabel="vav"];
  Trans -> Omega [xlabel="vav"];
  legend -> Omega [style=invis];
}
