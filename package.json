{
  "name": "hebrew-operator-vm",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/ui"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ui:dev": "npm run dev --workspace @letters/ui",
    "ui:build": "npm run build --workspace @letters/ui",
    "ui:preview": "npm run preview --workspace @letters/ui",
    "ui:e2e": "playwright test -c playwright.config.ts",
    "ui:bundle": "node scripts/ui-bundle.mjs",
    "ui:bundle:verify": "node scripts/ui-bundle.mjs verify",
    "download-torah": "node scripts/download-torah.mjs",
    "iterate-torah": "node scripts/iterate-torah.mjs",
    "pasuk-trace": "node scripts/pasuk-trace.mjs",
    "normalize-torah": "node scripts/normalize-torah.mjs",
    "normalize-torah:verify": "node scripts/normalize-torah.mjs verify",
    "teamim-registry": "node scripts/teamim-registry.mjs",
    "teamim-registry:verify": "node scripts/teamim-registry.mjs verify",
    "phrase-tree": "node scripts/phrase-tree.mjs",
    "phrase-tree:verify": "node scripts/phrase-tree.mjs verify",
    "token-registry": "node scripts/extract-token-registry.mjs",
    "token-registry:verify": "node scripts/extract-token-registry.mjs verify",
    "token-compile": "node scripts/compile-token-operators.mjs",
    "token-compile:verify": "node scripts/compile-token-operators.mjs verify",
    "torah-corpus": "node scripts/torah-corpus.mjs run-all",
    "torah-corpus:execute": "node scripts/torah-corpus.mjs execute",
    "torah-corpus:diff": "node scripts/torah-corpus.mjs diff",
    "torah-corpus:promote": "node scripts/torah-corpus.mjs promote",
    "torah-corpus:verify": "node scripts/torah-corpus.mjs verify",
    "torah-corpus:regress": "node scripts/torah-corpus.mjs regress",
    "pattern-index": "node scripts/pattern-index.mjs build",
    "pattern-query": "node scripts/pattern-index.mjs query",
    "exemplars": "node scripts/exemplar-library.mjs build",
    "exemplars:verify": "node scripts/exemplar-library.mjs verify",
    "render:atomic": "node impl/reference/dist/scripts/renderAtomic/runtime.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"impl/reference/src/**/*.ts\" \"tests/**/*.ts\"",
    "ci:guardrails": "node scripts/ci-guardrails.cjs --mode=fail --allowlist=config/guardrails-allowlist.json --report=reports/ci_guardrails_baseline.md",
    "ci:version-contract": "node scripts/check-version-contract.cjs --mode=fail",
    "ci:mjs-policy": "node scripts/check-mjs-policy.cjs --mode=fail --allowlist=config/mjs-policy-allowlist.json --report=reports/mjs_policy_violations.md",
    "format": "prettier --check \"impl/reference/src/**/*.{ts,md,json,yaml,yml}\" \"tests/**/*.{ts,md,json,yaml,yml}\" \"spec/**/*.md\" \"registry/**/*.{yml,yaml}\" \"letters/**/*.md\" \"modifiers/**/*.md\" \"profiles/**/*.md\" \"theory/**/*.md\" \"examples/**/*.md\" \"README.md\" \".github/**/*.{yml,yaml,md}\"",
    "format:write": "prettier --write \"impl/reference/src/**/*.{ts,md,json,yaml,yml}\" \"tests/**/*.{ts,md,json,yaml,yml}\" \"spec/**/*.md\" \"registry/**/*.{yml,yaml}\" \"letters/**/*.md\" \"modifiers/**/*.md\" \"profiles/**/*.md\" \"theory/**/*.md\" \"examples/**/*.md\" \"README.md\" \".github/**/*.{yml,yaml,md}\"",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.23.2",
    "prettier": "^3.3.3",
    "typescript": "5.5.4",
    "vitest": "^1.5.0"
  }
}
