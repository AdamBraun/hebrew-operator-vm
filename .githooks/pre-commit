#!/bin/sh
set -e

if [ -z "$(git diff --cached --name-only --diff-filter=ACMR)" ]; then
  exit 0
fi

# Use a NUL-delimited staged file list and process in chunks to avoid shell arg limits.
staged_list_file="$(mktemp)"
trap 'rm -f "$staged_list_file"' EXIT INT TERM
git diff --cached --name-only --diff-filter=ACMR -z > "$staged_list_file"

xargs -0 -n 200 npm exec -- prettier --ignore-unknown --write -- < "$staged_list_file"
xargs -0 -n 200 git add -- < "$staged_list_file"

npm run src-artifacts:recompute -- --changed-only --staged
